# Ignore build output
target/
build/

# If you have multi-module Maven or Gradle projects, you can allow source-level builds
!**/src/main/**/build/
!**/src/test/**/build/

# Maven wrapper jar (optional: track or ignore)
.mvn/wrapper/maven-wrapper.jar

